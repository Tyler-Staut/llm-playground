# Example environment variables for llm-playground

# PostgreSQL credentials (used by LiteLLM)
POSTGRES_PASSWORD=litellm_secret

# Master key used by LiteLLM (and also by OpenWebUI as API key)
LITELLM_MASTER_KEY=playground

# Optional secret for OpenWebUI (server-side encryption of sessions etc.)
WEBUI_SECRET_KEY=change-me-in-production
OPEN_TERMINAL_API_KEY=change-me-in-production

# API keys for providers (leave blank or remove if you don't use a provider)
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Add any additional provider keys or overrides below:
# ANOTHER_PROVIDER_API_KEY=
